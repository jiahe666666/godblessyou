# ==================== 数据库 ====================
DB_NAME=lottery_system
DB_USERNAME=lottery
DB_PASSWORD=lottery123
DB_ROOT_PASSWORD=root123456
MYSQL_PORT=3306

# ==================== Redis ====================
REDIS_PORT=6379

# ==================== 邮件发送 ====================
# SMTP Relay 配置（587/465 端口，无需 25 端口）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587

# SMTP 登录凭据（QQ/163 填邮箱地址，Postmark/SendGrid 填 API Key）
SMTP_USER=your-email@qq.com
SMTP_PASS=你的授权码

# 发件人地址（QQ/163 留空自动等同 SMTP_USER；Postmark/SendGrid 必须填已验证的邮箱）
SMTP_FROM=

SMTP_AUTH=true
SMTP_STARTTLS=true
MAIL_DEBUG=false

# ---- 常用 SMTP 配置速查 ----
# QQ邮箱:  SMTP_HOST=smtp.qq.com         SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true   SMTP_USER=xxx@qq.com  SMTP_PASS=授权码
# 163邮箱: SMTP_HOST=smtp.163.com        SMTP_PORT=465  SMTP_AUTH=true  SMTP_STARTTLS=false  SMTP_USER=xxx@163.com SMTP_PASS=授权码
# Postmark:SMTP_HOST=smtp.postmarkapp.com SMTP_PORT=587 SMTP_AUTH=true  SMTP_STARTTLS=true   SMTP_USER=API-Token    SMTP_PASS=API-Token  SMTP_FROM=已验证的发件邮箱
# SendGrid:SMTP_HOST=smtp.sendgrid.net   SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true   SMTP_USER=apikey       SMTP_PASS=SG.xxx      SMTP_FROM=已验证的发件邮箱
# AWS SES: SMTP_HOST=email-smtp.us-east-1.amazonaws.com SMTP_PORT=587 SMTP_AUTH=true SMTP_STARTTLS=true SMTP_USER=xxx SMTP_PASS=xxx SMTP_FROM=已验证的发件邮箱
# 阿里企业邮:SMTP_HOST=smtp.mxhichina.com SMTP_PORT=465 SMTP_AUTH=true  SMTP_STARTTLS=false

# ---- 内置 postfix（需 25 端口，启动加 --profile mail）----
# SMTP_HOST=postfix  SMTP_PORT=587  SMTP_AUTH=false  SMTP_STARTTLS=false
# SMTP_USER=noreply@example.com  SMTP_PASS=changeit  POSTFIX_DOMAIN=example.com

# ==================== 前端访问地址 ====================
FRONTEND_BASE_URL=http://localhost
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ==================== 服务端口 ====================
BACKEND_PORT=8080
FRONTEND_PORT=80

# ==================== 安全 ====================
JWT_SECRET=change-this-to-a-random-64-char-secret

# ==================== 管理员初始账号 ====================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# ==================== 抽奖规则 ====================
LOTTERY_DAILY_LIMIT=10
LOTTERY_COOLDOWN_SECONDS=5