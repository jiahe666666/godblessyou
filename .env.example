# ==================== 数据库 ====================
DB_NAME=lottery_system
DB_USERNAME=lottery
DB_PASSWORD=lottery123
DB_ROOT_PASSWORD=root123456
MYSQL_PORT=3306

# ==================== Redis ====================
REDIS_PORT=6379

# ==================== 邮件发送 ====================
# 填入你的 SMTP Relay 信息（QQ/163/SendGrid/AWS SES 等，端口 587/465，无需 25 端口）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=你的授权码
SMTP_AUTH=true
SMTP_STARTTLS=true
MAIL_DEBUG=false

# ---- 国内常用 SMTP 速查 ----
# QQ邮箱:   SMTP_HOST=smtp.qq.com        SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true   密码填授权码
# 163邮箱:  SMTP_HOST=smtp.163.com       SMTP_PORT=465  SMTP_AUTH=true  SMTP_STARTTLS=false  密码填授权码
# 阿里企业邮: SMTP_HOST=smtp.mxhichina.com SMTP_PORT=465  SMTP_AUTH=true  SMTP_STARTTLS=false
# SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true   密码填API Key
# AWS SES:  SMTP_HOST=email-smtp.us-east-1.amazonaws.com SMTP_PORT=587 SMTP_AUTH=true SMTP_STARTTLS=true

# ---- 或使用内置 postfix（需 25 端口，启动时加 --profile mail）----
# SMTP_HOST=postfix
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=changeit
# SMTP_AUTH=false
# SMTP_STARTTLS=false
# POSTFIX_DOMAIN=example.com

# ==================== 前端访问地址 ====================
FRONTEND_BASE_URL=http://localhost
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ==================== 服务端口 ====================
BACKEND_PORT=8080
FRONTEND_PORT=80

# ==================== 安全 ====================
JWT_SECRET=change-this-to-a-random-64-char-secret

# ==================== 管理员初始账号 ====================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456

# ==================== 抽奖规则 ====================
LOTTERY_DAILY_LIMIT=10
LOTTERY_COOLDOWN_SECONDS=5