# ==================== 数据库 ====================
DB_NAME=lottery_system
DB_USERNAME=lottery
DB_PASSWORD=lottery123
DB_ROOT_PASSWORD=root123456
MYSQL_PORT=3306

# ==================== Redis ====================
REDIS_PORT=6379

# ==================== 邮件发送 ====================
# 默认使用 MailHog（开发/测试用，邮件不会真正发出，在 http://localhost:8025 查看）
# 生产环境请改为真实 SMTP Relay：
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=noreply@lottery.local
SMTP_PASS=
SMTP_AUTH=false
SMTP_STARTTLS=false
MAIL_DEBUG=false
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---- 生产环境 SMTP Relay 配置参考（取消注释并填入真实信息）----
# QQ邮箱:   SMTP_HOST=smtp.qq.com        SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true  SMTP_USER=xxx@qq.com  SMTP_PASS=授权码
# 163邮箱:  SMTP_HOST=smtp.163.com       SMTP_PORT=465  SMTP_AUTH=true  SMTP_STARTTLS=false SMTP_USER=xxx@163.com SMTP_PASS=授权码
# 阿里企业邮: SMTP_HOST=smtp.mxhichina.com SMTP_PORT=465  SMTP_AUTH=true  SMTP_STARTTLS=false
# SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_AUTH=true  SMTP_STARTTLS=true  SMTP_USER=apikey  SMTP_PASS=SG.xxx
# AWS SES:  SMTP_HOST=email-smtp.us-east-1.amazonaws.com SMTP_PORT=587 SMTP_AUTH=true SMTP_STARTTLS=true  SMTP_USER=xxx  SMTP_PASS=xxx

# ---- 使用内置 postfix 容器（需要 25 端口，启动加 --profile mail）----
# SMTP_HOST=postfix
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=changeit
# SMTP_AUTH=false
# SMTP_STARTTLS=false
# POSTFIX_DOMAIN=example.com

# ==================== 前端访问地址 ====================
FRONTEND_BASE_URL=http://localhost
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ==================== 服务端口 ====================
BACKEND_PORT=8080
FRONTEND_PORT=80

# ==================== 安全 ====================
JWT_SECRET=change-this-to-a-random-64-char-secret

# ==================== 管理员初始账号 ====================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@lottery.local
ADMIN_PASSWORD=Admin@123456

# ==================== 抽奖规则 ====================
LOTTERY_DAILY_LIMIT=10
LOTTERY_COOLDOWN_SECONDS=5